# Copy to .env.traefik and edit, then source it before `docker compose ... up`.
# Defaults in docker-compose.traefik.yml already point at fdp.expert and the
# git email — override here if you ever change domain or move to a dedicated
# ops inbox.

# Domain served by Kendraw. Used by both compose files (frontend labels
# include Host(fdp.expert) || Host(www.fdp.expert)).
KENDRAW_DOMAIN=fdp.expert

# Contact address for Let's Encrypt. Expiration reminders + rate-limit
# contact go here. MUST be a real mailbox you read.
ACME_EMAIL=jbdpetracco@gmail.com
