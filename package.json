{
  "name": "kendraw",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open-source modern web successor to ChemDraw",
  "author": "Jean-Baptiste Donnette <electrosenpai@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/electrosenpai/kendraw.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=4 test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "build": "pnpm --filter @kendraw/ui build",
    "dev": "pnpm --filter @kendraw/ui dev",
    "dev:full": "concurrently -n fe,be -c cyan,green \"pnpm dev\" \"cd backend && uvicorn kendraw_api.main:app --host 0.0.0.0 --port 8081 --reload\"",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "depcruise": "depcruise packages/*/src --config .dependency-cruiser.cjs",
    "size-limit": "size-limit",
    "license-check": "license-checker --onlyAllow \"MIT;BSD-2-Clause;BSD-3-Clause;Apache-2.0;ISC;0BSD;Unlicense;CC0-1.0;CC-BY-4.0;BlueOak-1.0.0;Python-2.0\" --excludePrivatePackages",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:new-canvas": "VITE_ENABLE_NEW_CANVAS=true playwright test --project=chromium-new-canvas",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "path": "packages/ui/dist/assets/*.js",
      "limit": "400 kB",
      "gzip": true
    }
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/mcp": "^0.0.73",
    "@playwright/test": "^1.59.1",
    "@rdkit/rdkit": "2025.3.4-1.0.0",
    "@seontechnologies/playwright-utils": "^4.3.0",
    "@size-limit/preset-app": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "jspdf": "^4.2.1"
  }
}
