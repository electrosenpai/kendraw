#!/bin/sh

echo "Pre-commit checks..."

# CHECK 0: Unresolved merge conflicts (use git's built-in check)
echo "-> Merge conflict markers..."
if ! git diff --cached --check 2>/dev/null; then
  echo "BLOCKED: Unresolved merge conflicts or whitespace errors in staged files"
  exit 1
fi

# CHECK 1: Python syntax on staged .py files
echo "-> Python syntax..."
PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
for f in $PY_FILES; do
  if [ -f "$f" ]; then
    python3 -m py_compile "$f" || { echo "Python syntax error: $f"; exit 1; }
  fi
done

# Frontend
echo "-> ESLint..."
pnpm lint || { echo "Frontend lint failed"; exit 1; }

echo "-> TypeScript..."
pnpm typecheck || { echo "TypeScript failed"; exit 1; }

echo "-> Frontend tests..."
pnpm test || { echo "Frontend tests failed"; exit 1; }

# Backend
echo "-> Ruff check..."
cd backend && uv run ruff check . || { echo "Ruff check failed"; exit 1; }

echo "-> Ruff format..."
uv run ruff format --check . || { echo "Ruff format failed"; exit 1; }

echo "-> mypy..."
uv run mypy kendraw_api/ kendraw_chem/ kendraw_settings/ kendraw_observability/ || { echo "mypy failed"; exit 1; }

echo "-> Backend tests..."
uv run pytest -v || { echo "Backend tests failed"; exit 1; }

cd ..
echo "All checks passed -- committing."
